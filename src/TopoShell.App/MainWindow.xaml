<Window x:Class="TopoShell.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TopoShell Phase 0"
        Width="1280"
        Height="760"
        MinWidth="1000"
        MinHeight="640"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#050505"
        Foreground="#F1F1F1"
        FontFamily="Segoe UI"
        Focusable="True"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        MouseMove="Window_MouseMove"
        MouseLeave="Window_MouseLeave"
        PreviewKeyDown="Window_KeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelFill" Color="#D0070707" />
        <SolidColorBrush x:Key="PanelLine" Color="#70F2F2F2" />
        <SolidColorBrush x:Key="SoftLine" Color="#45FFFFFF" />
        <SolidColorBrush x:Key="TextHigh" Color="#F5F5F5" />
        <SolidColorBrush x:Key="TextMid" Color="#B8B8B8" />
        <SolidColorBrush x:Key="TextLow" Color="#707070" />

        <Style x:Key="ChromeButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="#151515" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E6E6E6" />
                                <Setter Property="Foreground" Value="#050505" />
                                <Setter Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelFill}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelLine}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="#111111" />
            <Setter Property="BorderBrush" Value="#6CFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E6E6E6" />
                                <Setter Property="Foreground" Value="#050505" />
                                <Setter Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Setter Property="Foreground" Value="#000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DockButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Foreground" Value="#EFEFEF" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252525" />
                                <Setter Property="BorderBrush" Value="#E8FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E6E6E6" />
                                <Setter Property="Foreground" Value="#050505" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root" ClipToBounds="True">
        <Grid.Background>
            <RadialGradientBrush Center="0.50,0.52" GradientOrigin="0.50,0.52" RadiusX="0.86" RadiusY="0.96">
                <GradientStop Color="#222222" Offset="0" />
                <GradientStop Color="#090909" Offset="0.48" />
                <GradientStop Color="#020202" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>

        <Canvas x:Name="SceneCanvas" IsHitTestVisible="False">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="FineGridTransform" />
            </Canvas.RenderTransform>
            <Canvas x:Name="GridCanvas" Opacity="0.24" />
            <Canvas x:Name="TerrainCanvas" Opacity="0.26">
                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="TerrainTransform" />
                </Canvas.RenderTransform>
            </Canvas>
        </Canvas>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="86" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="42"
                    Style="{StaticResource PanelBorderStyle}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="TOPO SHELL"
                                   FontFamily="Consolas"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHigh}" />
                        <TextBlock Text=" // 3D MECHANICAL CORE"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource TextLow}"
                                   Margin="8,2,0,0" />
                        <Border Width="1" Height="18" Background="#55FFFFFF" Margin="18,0" />
                        <TextBlock x:Name="StatusText"
                                   Text="MONO CORE // INITIALIZING"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMid}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="X" Style="{StaticResource ChromeButtonStyle}" Click="Close_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="LeftRailTransform" />
                    </StackPanel.RenderTransform>
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="CONFIG VECTOR" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextHigh}" />
                            <TextBlock Text="DOCK PROFILE ONLINE" Margin="0,14,0,0" FontFamily="Consolas" Foreground="{StaticResource TextHigh}" />
                            <TextBlock Text="bottom shortcuts are loaded from dock-shortcuts.json beside the app."
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"
                                       LineHeight="19"
                                       Foreground="{StaticResource TextLow}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="INPUT ATTITUDE" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextHigh}" />
                            <TextBlock x:Name="ParallaxText" Text="+0.00 / +0.00" Margin="0,12,0,0" FontFamily="Consolas" FontSize="21" />
                            <TextBlock x:Name="AngleText" Text="000 DEG" Margin="0,8,0,0" FontFamily="Consolas" Foreground="{StaticResource TextMid}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinWidth="0">
                    <Viewbox Stretch="Uniform"
                             StretchDirection="Both"
                             MaxWidth="1060"
                             MaxHeight="900"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,4,0,0">
                        <Grid Width="660" Height="620" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="CoreHudTransform" />
                            </Grid.RenderTransform>

                            <Viewport3D x:Name="CoreViewport"
                                        Width="640"
                                        Height="600"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ClipToBounds="False"
                                        IsHitTestVisible="False" />

                            <Canvas Width="660" Height="620" IsHitTestVisible="False">
                                <Line X1="330" Y1="24" X2="330" Y2="106" Stroke="#88FFFFFF" StrokeThickness="1" />
                                <Line X1="330" Y1="514" X2="330" Y2="596" Stroke="#55FFFFFF" StrokeThickness="1" />
                                <Line X1="44" Y1="310" X2="128" Y2="310" Stroke="#55FFFFFF" StrokeThickness="1" />
                                <Line X1="532" Y1="310" X2="616" Y2="310" Stroke="#88FFFFFF" StrokeThickness="1" />
                                <Polyline Points="170,112 124,112 124,176" Stroke="#55FFFFFF" StrokeThickness="1" />
                                <Polyline Points="490,508 536,508 536,444" Stroke="#55FFFFFF" StrokeThickness="1" />
                                <TextBlock Text="CORE-00" Canvas.Left="288" Canvas.Top="70" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMid}" />
                                <TextBlock Text="DEPTH / ACTIVE" Canvas.Left="452" Canvas.Top="492" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextLow}" />
                            </Canvas>

                        </Grid>
                    </Viewbox>
                </Grid>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="RightRailTransform" />
                    </StackPanel.RenderTransform>
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="3D CORE" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextHigh}" />
                            <TextBlock Text="extruded rings and plates rotate in real perspective, not a flat HUD skin."
                                       TextWrapping="Wrap"
                                       Margin="0,14,0,0"
                                       LineHeight="19"
                                       Foreground="{StaticResource TextLow}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="DATA PROVIDERS" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextHigh}" />
                            <TextBlock Text="CPU   KERNEL32" Margin="0,14,0,0" FontFamily="Consolas" Foreground="{StaticResource TextHigh}" />
                            <TextBlock Text="MEM   KERNEL32" Margin="0,8,0,0" FontFamily="Consolas" Foreground="{StaticResource TextHigh}" />
                            <TextBlock Text="GPU   RESERVED" Margin="0,8,0,0" FontFamily="Consolas" Foreground="{StaticResource TextMid}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Height="64"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="2,0,10,0">
                        <TextBlock Text="DOCK"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHigh}" />
                        <TextBlock Text="dock-shortcuts.json"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="{StaticResource TextLow}" />
                    </StackPanel>
                    <ScrollViewer Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  VerticalAlignment="Center"
                                  Focusable="False">
                        <StackPanel x:Name="DockItemsPanel"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center" />
                    </ScrollViewer>
                    <Button Grid.Column="2"
                            Content="CTRL+SPACE"
                            Style="{StaticResource CommandButtonStyle}"
                            Margin="12,0,0,0"
                            MinWidth="112"
                            Height="34"
                            Click="CommandSlot_Click" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="CommandPanel"
                Width="620"
                Height="318"
                Visibility="Collapsed"
                Style="{StaticResource PanelBorderStyle}"
                Padding="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <Grid>
                    <TextBlock Text="COMMAND SLOT" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextHigh}" />
                    <TextBlock x:Name="CommandStateText"
                               Text="RUNTIME // READY"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="{StaticResource TextLow}"
                               HorizontalAlignment="Right" />
                </Grid>
                <TextBox x:Name="SearchBox"
                         Height="42"
                         Margin="0,16,0,14"
                         Background="#E6070707"
                         BorderBrush="#90FFFFFF"
                         Foreground="#F2F2F2"
                         CaretBrush="#FFFFFF"
                         FontFamily="Consolas"
                         FontSize="15"
                         Padding="12,8"
                         Text="runtime controls" />
                <WrapPanel>
                    <Button x:Name="MotionToggleButton"
                            Content="MOTION ON"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="ToggleMotion_Click" />
                    <Button x:Name="AudioToggleButton"
                            Content="AUDIO ON"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="ToggleAudio_Click" />
                    <Button x:Name="TopmostToggleButton"
                            Content="TOPMOST OFF"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="ToggleTopmost_Click" />
                    <Button Content="RESET VIEW"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="ResetParallax_Click" />
                    <Button Content="EXIT SHELL"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="ExitShell_Click" />
                </WrapPanel>
                <Border Height="1" Margin="0,6,0,12" Background="#45FFFFFF" />
                <TextBlock Text="PROFILE RAILS DEFERRED // SYSTEM CONTROLS ACTIVE"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="{StaticResource TextLow}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
